NODE_ENV=development
PORT=8000
HOST=0.0.0.0

DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_sql_assistant

# Set true (or run `npm run dev:stub`) to run the API without Postgres — mock /schema and /execute.
STUB_DATABASE=false

# Real Postgres + Ollama in Docker, then API (one command): npm run dev:stack

# --- LLM: paid OpenAI OR free local Ollama (OpenAI-compatible) ---
# Option A — OpenAI (paid): set key, leave OPENAI_BASE_URL unset
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Option B — Ollama (free, local): install https://ollama.com then:
#   ollama pull llama3.2
#   ollama serve
# Then use (API key is ignored by Ollama but required by the client):
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.2
# OPENAI_RESPONSE_FORMAT=none
OPENAI_BASE_URL=
OPENAI_RESPONSE_FORMAT=json_object

# Statement timeout for /execute (ms)
DB_STATEMENT_TIMEOUT_MS=30000

# Rate limit: max requests per window per IP
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000

# Comma-separated origins; * allows all (dev only)
CORS_ORIGIN=http://localhost:3000

# Optional: disable UPDATE in generated SQL (server still blocks non-SELECT execution)
ALLOW_UPDATE_IN_AI_GENERATION=false

# In-memory cache TTL for identical /query prompts (seconds); 0 disables
QUERY_CACHE_TTL_SECONDS=60
